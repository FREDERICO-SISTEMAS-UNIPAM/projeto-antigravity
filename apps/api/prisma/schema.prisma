datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum RawSource {
  WHATSAPP_GRUPO_DL
  WHATSAPP_DISPONIVEIS
  IFOOD_HISTORIC
  RYD
  MANUAL
}

enum DeliveryStatus {
  PENDING
  IN_PROGRESS
  DELIVERED
  CANCELED
}

enum DevicePlatform {
  ANDROID
  IOS
}

enum UserRole {
  ADMIN
  MANAGER
  DISPATCHER
  MOTOBOY
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  password     String?
  role         UserRole      @default(MOTOBOY)
  tenantId     String?
  deviceTokens DeviceToken[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model City {
  id               String            @id @default(uuid())
  name             String
  state            String
  slug             String            @unique
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  neighborhoods    Neighborhood[]
  deliveryRequests DeliveryRequest[]
  contacts         Contact[]
}

model Neighborhood {
  id        String   @id @default(uuid())
  name      String
  latitude  Float?
  longitude Float?
  bounds    Json?
  cityId    String
  city      City     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cityId, name])
}

model DeviceToken {
  id            String         @id @default(uuid())
  userId        String?
  user          User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  fcmToken      String         @unique
  bleMacAddress String?
  bleSettings   Json?
  platform      DevicePlatform @default(ANDROID)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model DeliveryRequest {
  id                   String         @id @default(uuid())
  messageHash          String?        @unique
  rawSource            RawSource
  requesterName        String?
  requesterPhone       String?
  pickupLocation       String
  pickupNeighborhood   String
  deliveryAddress      String?
  deliveryNeighborhood String
  deliveryFee          Decimal?       @db.Decimal(10, 2)
  requestedAt          DateTime
  dayOfWeek            Int
  hourOfDay            Int
  status               DeliveryStatus @default(PENDING)
  cityId               String?
  city                 City?          @relation(fields: [cityId], references: [id], onDelete: SetNull)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@index([deliveryNeighborhood])
  @@index([pickupNeighborhood])
  @@index([requestedAt])
  @@index([dayOfWeek, hourOfDay])
  @@index([cityId])
}

model GeocodingCache {
  id        String   @id @default(uuid())
  address   String   @unique
  latitude  Float
  longitude Float
  createdAt DateTime @default(now())
}

model Contact {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  address   String?
  cityId    String?
  city      City?    @relation(fields: [cityId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AiPredictionLog {
  id                     String   @id @default(uuid())
  currentNeighborhood    String
  recommendedNeighborhood String
  confidencePercentage   Int
  reasoning              String
  expectedAverageFee     Float
  engineSource           String
  feedbackRating         Int?
  createdAt              DateTime @default(now())
}

model RealtimeEvent {
  id        String   @id @default(uuid())
  eventType String
  payload   Json
  createdAt DateTime @default(now())
}
